    "primereact": "^9.5.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "superjson": "1.12.3",
    "swr": "^2.1.5",
    "tinymce": "^6.4.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@o4s/eslint-config": "^0.1.0",
    "@types/cors": "^2.8.13",
    "@types/md5": "^2.3.2",
    "@types/node": "^20.2.3",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "autoprefixer": "^10.4.14",
    "dotenv-cli": "^7.2.1",
    "eslint": "^8.42.0",
    "typescript": "^5.0.4"
