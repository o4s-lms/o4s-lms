    "@o4s/db": "^0.1.0",
    "@o4s/generated-wundergraph": "^0.1.0",
    "@o4s/lib": "^0.1.0",
    "@o4s/postcss-config": "^0.1.0",
    "@sindresorhus/slugify": "^2.2.0",
    "@t3-oss/env-nextjs": "^0.4.0",
    "@tanstack/react-query": "^4.29.12",
    "@teamhanko/hanko-elements": "^0.5.5-beta",
    "@tinymce/tinymce-react": "^4.3.0",
    "@wundergraph/nextjs": "^0.11.8",
    "cookies-next": "^2.1.1",
    "cors": "^2.8.5",
    "md5": "^2.3.0",
    "next": "^13.4.4",
    "nodemailer": "^6.9.3",
    "primeflex": "^3.3.1",
