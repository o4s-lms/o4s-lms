    "@tailwindcss/typography": "^0.5.9",
    "@types/ms": "^0.7.31",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.0.1",
    "dotenv-cli": "^7.2.1",
    "postcss": "^8.4.23",
    "prettier": "^2.8.8",
