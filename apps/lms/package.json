    "@o4s/generated-wundergraph": "^0.1.0",
    "@radix-ui/react-popover": "^1.0.5",
    "@radix-ui/react-tooltip": "^1.0.5",
    "@types/node": "20.1.7",
    "@types/react": "18.2.6",
    "@types/react-dom": "18.2.4",
    "@vercel/og": "^0.5.4",
    "classnames": "^2.3.2",
    "daisyui": "^2.51.6",
    "eslint": "8.40.0",
    "eslint-config-next": "13.4.2",
    "focus-trap-react": "^10.1.2",
    "framer-motion": "^10.12.12",
    "lucide-react": "0.216.0",
