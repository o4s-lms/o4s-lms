model Faq {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	question		String
	answer			String
	order				Int
	locale			String

	@@map("faqs")
}

model Course {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	thumbnail		String
	price				String
	image				String
	title				String
	description	String
	slug				String
	include			String
	html				String?
	order				Int
	locale			String

	@@map("courses")
}

model Testimonial {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	avatar			String
	name				String
	title				String
	quote				String
	locale			String

	@@map("testimonials")
}


