generator client {
  provider        = "prisma-client-js"
	output   				= "../../../../node_modules/@prisma/client/site"
}

datasource db {
  provider     			= "mongodb"
  url          			= env("DATABASE_MONGODB_URL")
}

model Faqs {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	question		String
	answer			String
	order				Int
	locale			String

	@@map("faqs")
}

model Courses {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	thumbnail		String
	price				String
	image				String
	title				String
	description	String
	slug				String
	include			String
	html				String?
	order				Int
	locale			String

	@@map("courses")
}

model Testimonials {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	avatar			String
	name				String
	title				String
	quote				String
	locale			String

	@@map("testimonials")
}


