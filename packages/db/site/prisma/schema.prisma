generator client {
  provider        = "prisma-client-js"
	output   				= "../../../../node_modules/@prisma/client/site"
}

datasource db {
  provider     			= "mongodb"
  url          			= env("DATABASE_MONGODB_URL")
}

model Post {
	id          		String    @id @default(auto()) @map("_id") @db.ObjectId
	title						String
	slug						String		@unique
	mobiledoc				String?
	html						String?
	plaintext				String?
	image						String?
	featured				Boolean		@default(false)
	status					String		@default("draft")
	language				String		@default("pt")
	metaTitle				String?		@map("meta_title")
	metaDescription	String?		@map("meta_description")
	excerpt					String?
	estReadingTime	Int?			@map("est_reading_time")
	authorId 				String		@map("author_id") @db.ObjectId
	published				Boolean   @default(false)
	publishedAt			DateTime? @map("published_at")
	publishedBy			String? 	@map("published_by")
	createdAt				DateTime  @default(now())
	createdBy				String		@map("created_by")
	updatedAt				DateTime  @updatedAt
	updatedBy				String		@map("updated_by")
	ogImage					String?		@map("og_image")
	ogTitle					String?		@map("og_title")
	ogDescription		String?		@map("og_description")
	tagIDs 					String[]  @map("tag_ids") @db.ObjectId
  tags  					Tag[] 		@relation(fields: [tagIDs], references: [id])

	@@map("posts")
}

model Tag {
	id          		String    @id @default(auto()) @map("_id") @db.ObjectId
	name						String
	slug						String		@unique
	description			String?
	image						String?
	color						String?
	hidden					Boolean		@default(false)
	parentId 				String?		@map("parent_id") @db.ObjectId
	language				String		@default("pt")
	metaTitle				String?		@map("meta_title")
	metaDescription	String?		@map("meta_description")
	createdAt				DateTime  @default(now())
	createdBy				String		@map("created_by")
	updatedAt				DateTime  @updatedAt
	updatedBy				String		@map("updated_by")
	postIDs 				String[] 	@map("post_ids") @db.ObjectId
  posts   				Post[]   	@relation(fields: [postIDs], references: [id])

	@@map("tags")
}

model PostTag {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	postId			String		@map("post_id") @db.ObjectId
	tagId				String		@map("tag_id") @db.ObjectId

	@@unique([postId, tagId])

	@@map("post_tags")
}

model Faq {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	question		String
	answer			String
	order				Int
	locale			String

	@@map("faqs")
}

model Course {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	thumbnail		String
	price				String
	image				String
	title				String
	description	String
	slug				String
	include			String
	html				String?
	order				Int
	locale			String

	@@map("courses")
}

model Testimonial {
	id          String    @id @default(auto()) @map("_id") @db.ObjectId
	avatar			String
	name				String
	title				String
	quote				String
	locale			String

	@@map("testimonials")
}


